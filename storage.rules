rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Option B: restrict generated reports path while preserving authenticated app uploads.
    match /audit_reports/{auditId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
